# Supabase credentials — isi dengan project Anda (https://app.supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudinary — untuk upload foto KTP (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# api.co.id — untuk extract data KTP dari foto (https://api.co.id)
API_CO_ID_KEY=your-api-co-id-key
